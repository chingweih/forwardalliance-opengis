{
  "name": "@forwardalliance/opengis",
  "version": "1.0.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ForwardAlliance/opengis.git",
    "directory": "packages/opengis"
  },
  "scripts": {
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/geojson": "^7946.0.16",
    "@types/proj4": "^2.19.0",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@turf/turf": "^7.3.4",
    "csv-parse": "^6.1.0",
    "proj4": "^2.20.4",
    "zod": "^4.3.6"
  }
}
